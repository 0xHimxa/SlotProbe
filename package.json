{
  "name": "slotprobe",
  "version": "1.0.0",
  "description": "Smart contract state diffing and safe migration tooling for EVM protocols",
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "bin": {
    "slotprobe": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "src/core/migration/templates"
  ],
  "scripts": {
    "build": "tsup src/core/index.ts src/cli/index.ts --format esm --dts --outDir dist",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xHimxa/SlotProbe.git"
  },
  "keywords": [
    "evm",
    "solidity",
    "storage",
    "proxy",
    "upgrade",
    "snapshot",
    "diff",
    "migration",
    "web3"
  ],
  "author": "0xHimxa",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/0xHimxa/SlotProbe/issues"
  },
  "homepage": "https://github.com/0xHimxa/SlotProbe#readme",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "ethers": "^6.16.0",
    "handlebars": "^4.7.9",
    "ora": "^9.3.0",
    "p-limit": "^7.3.0",
    "p-retry": "^8.0.0",
    "viem": "^2.47.6",
    "zod": "^4.3.6"
  }
}
