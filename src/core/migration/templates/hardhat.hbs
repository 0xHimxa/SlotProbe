{{!--
  SlotProbe — Hardhat Migration Script Template

  Generates a Hardhat deploy script that applies each changed storage
  variable through its public setter function. The script connects to
  the deployed contract via ethers and calls setters sequentially,
  waiting for each transaction to be mined before proceeding.

  Template variables:
    contractName  — Name of the target contract (e.g. "UniswapV3Pool")
    address       — Deployed contract address (0x-prefixed)
    changes[]     — Array of DiffEntry objects with: name, solidityType, before, after
--}}
// SPDX-License-Identifier: MIT
// Generated by SlotProbe — https://github.com/0xHimxa/SlotProbe
// DO NOT EDIT — regenerate with: slotprobe generate-migration before.json after.json --format hardhat

import { ethers } from "hardhat";

const CONTRACT = "{{address}}";

async function main() {
  const [deployer] = await ethers.getSigners();
  console.log("Running migration with account:", deployer.address);

  const contract = await ethers.getContractAt("{{contractName}}", CONTRACT);

  {{#each changes}}
  // {{name}}: {{before}} -> {{after}}
  console.log("Setting {{name}}: {{before}} -> {{after}}");
  const tx{{@index}} = await contract.set{{capitalize name}}({{after}});
  await tx{{@index}}.wait();
  console.log("  ✅ {{name}} updated");

  {{/each}}
  console.log("Migration complete");
}

main().catch((error) => {
  console.error(error);
  process.exitCode = 1;
});
