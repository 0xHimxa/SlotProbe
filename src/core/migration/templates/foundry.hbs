{{!--
  SlotProbe — Foundry Migration Script Template
  
  Generates a Forge Script contract that applies each changed storage
  variable through its public setter function. The script broadcasts
  all setter calls inside a single vm.startBroadcast / vm.stopBroadcast
  block so they are submitted as one atomic transaction batch.
  
  Template variables:
    contractName  — Name of the target contract (e.g. "UniswapV3Pool")
    address       — Deployed contract address (0x-prefixed)
    changes[]     — Array of DiffEntry objects with: name, solidityType, before, after
--}}
// SPDX-License-Identifier: MIT
// Generated by SlotProbe — https://github.com/0xHimxa/SlotProbe
// DO NOT EDIT — regenerate with: slotprobe generate-migration before.json after.json --format foundry
pragma solidity ^0.8.19;

import "forge-std/Script.sol";

interface I{{contractName}} {
{{#each changes}}
    function set{{capitalize name}}({{solidityType}} value) external;
{{/each}}
}

contract Migrate{{contractName}} is Script {
    address constant CONTRACT = {{address}};

    function run() external {
        vm.startBroadcast();
        I{{contractName}} c = I{{contractName}}(CONTRACT);

        {{#each changes}}
        // {{name}}: {{before}} -> {{after}}
        c.set{{capitalize name}}({{after}});
        {{/each}}

        vm.stopBroadcast();
    }
}
